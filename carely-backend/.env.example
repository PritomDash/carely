PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/carely
JWT_SECRET=your_very_long_random_secret_key_here

# Email - falls through Brevo -> Resend -> SendGrid, all over HTTPS so it
# works on hosts (like Render) that block outbound raw SMTP. Brevo goes first
# since it uses the verified carely.help@gmail.com sender. See EMAIL_KEYS_NEEDED.md.
EMAIL_FROM=Carely <carely.help@gmail.com>
EMAIL_REPLY_TO=carely.help@gmail.com
BREVO_API_KEY=
BREVO_FROM_EMAIL=carely.help@gmail.com
RESEND_API_KEY=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

FRONTEND_URL=http://localhost:3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:dashpritom713@gmail.com
